        //},

        //"cpu": {
        //    "format": "َ°» ",
        //    "tooltip": true
        //},

        //"memory": {
        //    "format": "î؟…"
        //},

        //"temperature": {
        //    "critical-threshold": 80,
        //    "format": "ï‹‰",
        //},

        "tray": {
            "icon-size": 18,
            "spacing": 10
        },
}
